/* ── 3. Cards & Surfaces ────────────────────────────────── */

.aetox-card {
  border-radius: 40px;
  border-width: 1px;
  --tw-shadow: var(--aetox-shadow-card);
  --tw-shadow-colored: var(--aetox-shadow-card);
  box-shadow: var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), var(--tw-shadow);
