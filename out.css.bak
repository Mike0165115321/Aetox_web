/* ── 2. Inputs & Forms ──────────────────────────────────── */

.aetox-label {
  margin-bottom: 0.5rem;
  margin-left: 0.25rem;
  display: block;
  font-size: 0.75rem;
  line-height: 1;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  --tw-text-opacity: 1;
  color: rgb(var(--aetox-text-soft-rgb) / var(--tw-text-opacity, 1));
}

.aetox-input {
  width: 100%;
  border-radius: 1rem;
  border-width: 1px;
  --tw-border-opacity: 1;
  border-color: rgb(var(--aetox-border-rgb) / var(--tw-border-opacity, 1));
