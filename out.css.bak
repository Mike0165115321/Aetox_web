  transition-property: all;
  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  transition-duration: 300ms;
}

.aetox-input::-moz-placeholder {
  --tw-text-opacity: 1;
  color: rgb(var(--aetox-text-muted-rgb) / var(--tw-text-opacity, 1));
}

.aetox-input::placeholder {
  --tw-text-opacity: 1;
  color: rgb(var(--aetox-text-muted-rgb) / var(--tw-text-opacity, 1));
}

.aetox-input:focus {
  --tw-border-opacity: 1;
  border-color: rgb(var(--aetox-accent-rgb) / var(--tw-border-opacity, 1));
  outline: 2px solid transparent;
  outline-offset: 2px;
