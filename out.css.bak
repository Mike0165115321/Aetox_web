  transition-property: all;
  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  transition-duration: 500ms;
  background-color: var(--aetox-card-bg);
  border-color: var(--aetox-card-border);
}

.aetox-card:hover {
  background-color: var(--aetox-card-hover);
}

/* ── 4. Navigation ──────────────────────────────────────── */

.aetox-nav-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  border-radius: 32px;
  border-width: 1px;
  --tw-border-opacity: 1;
  border-color: rgb(var(--aetox-border-rgb) / var(--tw-border-opacity, 1));
  background-color: rgb(var(--aetox-surface-lowest-rgb) / 0.4);
  padding: 0.625rem;
  --tw-shadow: var(--aetox-shadow-card);
  --tw-shadow-colored: var(--aetox-shadow-card);
  box-shadow: var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), var(--tw-shadow);
  --tw-backdrop-blur: blur(40px);
  backdrop-filter: var(--tw-backdrop-blur) var(--tw-backdrop-brightness) var(--tw-backdrop-contrast) var(--tw-backdrop-grayscale) var(--tw-backdrop-hue-rotate) var(--tw-backdrop-invert) var(--tw-backdrop-opacity) var(--tw-backdrop-saturate) var(--tw-backdrop-sepia);
}

.aetox-nav-item {
  position: relative;
  display: flex;
  height: 3rem;
  width: 3rem;
  align-items: center;
  justify-content: center;
  border-radius: 20px;
  --tw-text-opacity: 1;
  color: rgb(var(--aetox-text-muted-rgb) / var(--tw-text-opacity, 1));
  transition-property: all;
  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  transition-duration: 500ms;
}

.aetox-nav-item:hover {
  --tw-scale-x: 1.1;
  --tw-scale-y: 1.1;
  transform: translate(var(--tw-translate-x), var(--tw-translate-y)) rotate(var(--tw-rotate)) skewX(var(--tw-skew-x)) skewY(var(--tw-skew-y)) scaleX(var(--tw-scale-x)) scaleY(var(--tw-scale-y));
  --tw-bg-opacity: 1;
  background-color: rgb(var(--aetox-accent-rgb) / var(--tw-bg-opacity, 1));
  --tw-text-opacity: 1;
  color: rgb(255 255 255 / var(--tw-text-opacity, 1));
}

.aetox-nav-item:active {
  --tw-scale-x: .95;
  --tw-scale-y: .95;
  transform: translate(var(--tw-translate-x), var(--tw-translate-y)) rotate(var(--tw-rotate)) skewX(var(--tw-skew-x)) skewY(var(--tw-skew-y)) scaleX(var(--tw-scale-x)) scaleY(var(--tw-scale-y));
}

.aetox-nav-item.active {
  --tw-bg-opacity: 1;
  background-color: rgb(var(--aetox-accent-rgb) / var(--tw-bg-opacity, 1));
  --tw-text-opacity: 1;
  color: rgb(255 255 255 / var(--tw-text-opacity, 1));
  --tw-shadow: var(--aetox-shadow-glow);
  --tw-shadow-colored: var(--aetox-shadow-glow);
  box-shadow: var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), var(--tw-shadow);
}

.aetox-nav-tooltip {
  border-radius: 20px;
  border-width: 1px;
  --tw-border-opacity: 1;
  border-color: rgb(var(--aetox-border-rgb) / var(--tw-border-opacity, 1));
  --tw-bg-opacity: 1;
  background-color: rgb(var(--aetox-surface-lowest-rgb) / var(--tw-bg-opacity, 1));
  padding-left: 1.25rem;
  padding-right: 1.25rem;
  padding-top: 0.625rem;
  padding-bottom: 0.625rem;
  --tw-shadow: var(--aetox-shadow-card);
  --tw-shadow-colored: var(--aetox-shadow-card);
  box-shadow: var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), var(--tw-shadow);
  --tw-backdrop-blur: blur(64px);
  backdrop-filter: var(--tw-backdrop-blur) var(--tw-backdrop-brightness) var(--tw-backdrop-contrast) var(--tw-backdrop-grayscale) var(--tw-backdrop-hue-rotate) var(--tw-backdrop-invert) var(--tw-backdrop-opacity) var(--tw-backdrop-saturate) var(--tw-backdrop-sepia);
}

/* ── 1. Atmosphere Components ───────────────────────────── */

.aetox-grid-overlay {
  pointer-events: none;
  position: absolute;
  inset: 0px;
  z-index: 0;
  background-image: radial-gradient(var(--aetox-border) 1px, transparent 1px);
  background-size: 40px 40px;
  -webkit-mask-image: radial-gradient(circle at center, black, transparent 80%);
          mask-image: radial-gradient(circle at center, black, transparent 80%);
  opacity: 0.15;
}

.aetox-aura-primary {
  pointer-events: none;
  position: absolute;
  height: 600px;
  width: 600px;
  border-radius: 9999px;
  background-color: rgb(var(--aetox-accent-rgb) / 0.2);
  mix-blend-mode: screen;
  --tw-blur: blur(120px);
  filter: var(--tw-blur) var(--tw-brightness) var(--tw-contrast) var(--tw-grayscale) var(--tw-hue-rotate) var(--tw-invert) var(--tw-saturate) var(--tw-sepia) var(--tw-drop-shadow);
  background: radial-gradient(circle, var(--aetox-accent) 0%, transparent 70%);
}

.aetox-aura-secondary {
  pointer-events: none;
  position: absolute;
  height: 500px;
  width: 500px;
  border-radius: 9999px;
  background-color: rgb(138 43 226 / 0.1);
  mix-blend-mode: screen;
  --tw-blur: blur(100px);
  filter: var(--tw-blur) var(--tw-brightness) var(--tw-contrast) var(--tw-grayscale) var(--tw-hue-rotate) var(--tw-invert) var(--tw-saturate) var(--tw-sepia) var(--tw-drop-shadow);
  background: radial-gradient(circle, #8A2BE2 0%, transparent 70%);
}

/* ── 2. Special Animation Effects ────────────────────────── */

.aetox-particle {
  pointer-events: none;
  position: absolute;
}

@keyframes pulse {
  50% {
    opacity: .5;
  }
}

.aetox-particle {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  border-radius: 9999px;
  background-color: rgb(var(--aetox-accent-rgb) / 0.2);
  --tw-blur: blur(1px);
  filter: var(--tw-blur) var(--tw-brightness) var(--tw-contrast) var(--tw-grayscale) var(--tw-hue-rotate) var(--tw-invert) var(--tw-saturate) var(--tw-sepia) var(--tw-drop-shadow);
}

.aetox-nav-indicator {
  position: absolute;
  inset: -0.375rem;
  z-index: -10;
  border-radius: 24px;
  background-color: rgb(var(--aetox-accent-rgb) / 0.3);
  --tw-blur: blur(12px);
  filter: var(--tw-blur) var(--tw-brightness) var(--tw-contrast) var(--tw-grayscale) var(--tw-hue-rotate) var(--tw-invert) var(--tw-saturate) var(--tw-sepia) var(--tw-drop-shadow);
}

